{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT o.id, o.name, o.slug, o.owner_id, o.created_at,\n               COUNT(m.user_id) AS \"member_count!\"\n        FROM organizations o\n        JOIN organization_members m ON m.organization_id = o.id\n        WHERE m.user_id = $1\n        GROUP BY o.id\n        ORDER BY o.created_at ASC\n        ",
