  "query": "\n        SELECT o.id, o.name, o.slug, o.owner_id, o.created_at\n        FROM organizations o\n        JOIN organization_members m ON m.organization_id = o.id\n        WHERE o.id = $1 AND m.user_id = $2\n        ",
