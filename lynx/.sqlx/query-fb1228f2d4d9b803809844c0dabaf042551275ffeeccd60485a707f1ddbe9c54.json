  "query": "\n        SELECT id, agent_id, organization_id, user_id,\n               command_type, result, error, entry_hash, created_at\n        FROM audit_log\n        WHERE agent_id = $1\n        ORDER BY created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
