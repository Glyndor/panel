  "query": "\n        SELECT m.user_id, u.username, m.role, m.joined_at\n        FROM organization_members m\n        JOIN users u ON u.id = m.user_id\n        WHERE m.organization_id = $1\n        ORDER BY m.joined_at ASC\n        ",
