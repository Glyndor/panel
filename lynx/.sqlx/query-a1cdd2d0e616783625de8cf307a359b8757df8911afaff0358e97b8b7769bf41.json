  "query": "\n        WITH new_org AS (\n            INSERT INTO organizations (id, name, slug, owner_id)\n            VALUES ($1, $2, $3, $4)\n            RETURNING *\n        ),\n        _ AS (\n            INSERT INTO organization_members (organization_id, user_id, role)\n            VALUES ($1, $4, 'owner')\n        )\n        SELECT id, name, slug, owner_id, created_at FROM new_org\n        ",
